{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/work", "destination": "/portfolio", "permanent": true },
    { "source": "/stuff", "destination": "/", "permanent": true },
    { "source": "/stuff/llms", "destination": "/", "permanent": true },
    { "source": "/services/ux-ui-design", "destination": "/services/website-products", "permanent": true },
    { "source": "/services/graphic-design", "destination": "/services/website-products", "permanent": true },
    { "source": "/services/website-development", "destination": "/services/website-products", "permanent": true },
    { "source": "/services/app-development", "destination": "/services/website-products", "permanent": true },
    { "source": "/services/ai-solutions", "destination": "/services/ai-agents", "permanent": true }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
